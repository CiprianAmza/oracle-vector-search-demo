# Configurare backend
# Copiaza ca `.env` si modifica daca e nevoie

# Conexiune Oracle (thin mode - fara Instant Client)
ORACLE_USER=vecuser
ORACLE_PWD_VECUSER=VecUser123
ORACLE_DSN=localhost:1521/FREEPDB1

# Pool de conexiuni
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4

# Server
APP_HOST=127.0.0.1
APP_PORT=8000
